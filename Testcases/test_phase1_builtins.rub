# Phase 1: Built-in Functions Test

# min / max
print(min(3, 1, 2))
print(max(3, 1, 2))
print(min([5, 2, 8]))
print(max([5, 2, 8]))

# sum
print(sum([1, 2, 3, 4, 5]))

# sorted
print(sorted([3, 1, 4, 1, 5]))

# abs
print(abs(-42))
print(abs(3.14))

# enumerate
let items = ["a", "b", "c"]
for pair in enumerate(items):
    print(pair)

# zip
let names = ["Alice", "Bob"]
let ages = [30, 25]
for pair in zip(names, ages):
    print(pair)

# reversed
print(reversed([1, 2, 3]))

# bool
print(bool(0))
print(bool(1))
print(bool(""))
print(bool("hi"))

# isinstance
print(isinstance(42, "int"))
print(isinstance("hi", "str"))
print(isinstance(42, "str"))

# map and filter
let nums = [1, 2, 3, 4, 5]
def double(x: int) -> int:
    return x * 2
def is_even(x: int) -> bool:
    return x % 2 == 0

print(map(double, nums))
print(filter(is_even, nums))

print("Phase 1: All built-in tests passed!")
