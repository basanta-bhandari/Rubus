# Test: String Methods
print("=== String Methods ===")
let s: str = "hello world"
print(s.upper())
print(s.replace("world", "Rubus"))
print(s.split(" "))
print(s.count("l"))
print(s.startswith("hello"))

# Test: List Methods  
print("\n=== List Methods ===")
let lst: list = [1, 2, 3, 4, 5]
lst.append(6)
print(lst)
lst.extend([7, 8])
print(lst)
print(lst.index(3))
print(lst.count(3))
lst.reverse()
print(lst)

# Test: Dict Methods
print("\n=== Dict Methods ===")
let d: dict = {"a": 1, "b": 2, "c": 3}
print(d.keys())
print(d.values())
print(d.get("a"))
print(d.get("z", "not found"))

# Test: Slicing
print("\n=== Slicing ===")
let arr: list = [10, 20, 30, 40, 50]
print(arr[1:4])
print(arr[::2])
print(arr[:3])
print(arr[2:])

let text: str = "Rubus"
print(text[1:4])
print(text[::2])

# Test: List Comprehension
print("\n=== List Comprehension ===")
let squares: list = [x * x for x in range(5)]
print(squares)

let evens: list = [x for x in range(10) if x % 2 == 0]
print(evens)

# Test: Dict Comprehension
print("\n=== Dict Comprehension ===")
let pairs: dict = {x: x * 2 for x in range(5)}
print(pairs)

let filtered: dict = {k: v for k, v in [("a", 1), ("b", 2), ("c", 3)] if k != "b"}
# This won't work directly since we need to iterate over a list of tuples

# Test: Type Checking
print("\n=== Type Checking ===")
let num: int = 42
print(num)

let name: str = "Alice"
print(name)
